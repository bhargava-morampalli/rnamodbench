{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "https://raw.githubusercontent.com/bhargava-morampalli/rnamodbench/master/assets/schema_input.json",
    "title": "bhargava-morampalli/rnamodbench pipeline - params.input schema",
    "description": "Schema for the file provided with params.input",
    "type": "array",
    "items": {
        "type": "object",
        "properties": {
            "sample": {
                "type": "string",
                "pattern": "^\\S+$",
                "errorMessage": "Sample name must be provided and cannot contain spaces",
                "meta": ["id"]
            },
            "fastq": {
                "type": "string",
                "format": "file-path",
                "pattern": "^\\S+\\.f(ast)?q(\\.gz)?$",
                "errorMessage": "FastQ file must be provided, cannot contain spaces and must have extension '.fq', '.fq.gz', '.fastq' or '.fastq.gz'"
            },
            "type": {
                "type": "string",
                "pattern": "^(native|ivt)$",
                "errorMessage": "Type must be either 'native' or 'ivt'",
                "meta": ["type"]
            },
            "replicate": {
                "type": "string",
                "pattern": "^\\S+$",
                "errorMessage": "Replicate identifier must be provided and cannot contain spaces",
                "meta": ["replicate"]
            },
            "fast5_dir": {
                "type": "string",
                "format": "directory-path",
                "pattern": "^\\S+$",
                "errorMessage": "FAST5 directory path must be provided and cannot contain spaces"
            },
            "target": {
                "type": "string",
                "pattern": "^[a-zA-Z0-9_]+[sS]?$",
                "errorMessage": "Target rRNA must be provided (e.g., 16s, 23s, 5s, 18s, 28s)",
                "meta": ["rrna"]
            }
        },
        "required": ["sample", "fastq", "type", "replicate", "fast5_dir", "target"]
    }
}
