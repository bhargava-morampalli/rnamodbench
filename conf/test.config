/*
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    Nextflow config file for running minimal tests
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    Defines input files and everything required to run a fast and simple pipeline test.

    Use as follows:
        nextflow run bhargava-morampalli/rnamodbench -profile test,<docker/singularity> --outdir <OUTDIR>

----------------------------------------------------------------------------------------
*/

params {
    config_profile_name        = 'Test profile'
    config_profile_description = 'Minimal test dataset to check pipeline function'

    // Limit resources so that this can run on GitHub Actions
    max_cpus   = 2
    max_memory = '6.GB'
    max_time   = '6.h'

    // Input data
    // Note: Test dataset should contain minimal FASTQ and FAST5 files
    // with at least one native and one IVT sample for the same replicate
    // Example samplesheet format:
    // sample,fastq,type,replicate,fast5_dir
    // native_rep1,native_rep1.fastq.gz,native,rep1,fast5/native_rep1
    // ivt_rep1,ivt_rep1.fastq.gz,ivt,rep1,fast5/ivt_rep1

    // Uncomment when test data is available:
    // input   = "${projectDir}/assets/test_samplesheet.csv"
    // ref_16s = "${projectDir}/assets/test_ref_16s.fa"
    // ref_23s = "${projectDir}/assets/test_ref_23s.fa"

    // Reduced thresholds for faster testing
    nanocompore_min_coverage = 1
    eligos_min_depth         = 1
    epinano_coverage_threshold = 1
}
