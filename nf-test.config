// nf-test configuration file
// See: https://www.nf-test.com/docs/configuration/

config {
    // Path to the Nextflow config file
    configFile "tests/nextflow.config"

    // Test profile to use (use conda since docker may not be available)
    profile "test,conda"

    // Location of tests (relative to project root)
    testsDir "."

    // Directory for test outputs
    workDir System.getenv("NFT_WORKDIR") ?: ".nf-test"

    // Ignore files in output assertions
    ignore ["versions.yml"]
}
