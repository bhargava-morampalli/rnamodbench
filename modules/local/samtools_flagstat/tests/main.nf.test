nextflow_process {

    name "Test Process SAMTOOLS_FLAGSTAT"
    script "../main.nf"
    process "SAMTOOLS_FLAGSTAT"

    tag "modules"
    tag "modules_local"
    tag "samtools"
    tag "samtools/flagstat"

    test("Should generate flagstat statistics from BAM file") {

        when {
            process {
                """
                input[0] = [
                    [ id: 'test', single_end: false ],
                    file("${projectDir}/modules/local/samtools_flagstat/tests/data/test.bam", checkIfExists: true)
                ]
                """
            }
        }

        then {
            assertAll(
                { assert process.success },
                { assert snapshot(process.out).match() }
            )
        }
    }

    test("Should work in stub mode") {

        options "-stub"

        when {
            process {
                """
                input[0] = [
                    [ id: 'test_stub', single_end: false ],
                    file("${projectDir}/modules/local/samtools_flagstat/tests/data/test.bam", checkIfExists: true)
                ]
                """
            }
        }

        then {
            assertAll(
                { assert process.success },
                { assert process.out.flagstat },
                { assert process.out.versions }
            )
        }
    }
}
