nextflow_process {

    name "Test Process ELIGOS_PAIR_DIFF_MOD"
    script "../main.nf"
    process "ELIGOS_PAIR_DIFF_MOD"

    tag "modules"
    tag "modules_local"
    tag "eligos_pair_diff_mod"
    tag "rna_modifications"

    test("Should work in stub mode") {

        options "-stub"

        when {
            process {
                """
                // Create minimal test files for stub mode
                def meta = [id: 'test_16s_rep1', rrna: '16s', replicate: 'rep1']

                // Create stub BAM files
                def native_bam = file("native.bam")
                native_bam.text = "stub"
                def native_bai = file("native.bam.bai")
                native_bai.text = "stub"
                def ivt_bam = file("ivt.bam")
                ivt_bam.text = "stub"
                def ivt_bai = file("ivt.bam.bai")
                ivt_bai.text = "stub"

                input[0] = [
                    meta,
                    native_bam,
                    native_bai,
                    ivt_bam,
                    ivt_bai,
                    file("${projectDir}/test_data/references/16S.fa", checkIfExists: true)
                ]
                """
            }
        }

        then {
            assertAll(
                { assert process.success },
                { assert process.out.results },
                { assert process.out.versions }
            )
        }
    }
}
