nextflow_process {

    name "Test Process MULTI_TO_SINGLE_FAST5"
    script "../main.nf"
    process "MULTI_TO_SINGLE_FAST5"

    tag "modules"
    tag "modules_local"
    tag "multi_to_single_fast5"
    tag "nanopore"

    test("Should convert multi-read fast5 to single-read fast5 files") {

        when {
            process {
                """
                input[0] = [
                    [ id: 'test' ],
                    file("${projectDir}/modules/local/multi_to_single_fast5/tests/data/multi_fast5", checkIfExists: true)
                ]
                """
            }
        }

        then {
            assertAll(
                { assert process.success },
                { assert snapshot(process.out).match() }
            )
        }
    }

    test("Should work in stub mode") {

        options "-stub"

        when {
            process {
                """
                input[0] = [
                    [ id: 'test_stub' ],
                    file("${projectDir}/modules/local/multi_to_single_fast5/tests/data/multi_fast5", checkIfExists: true)
                ]
                """
            }
        }

        then {
            assertAll(
                { assert process.success },
                { assert process.out.fast5 },
                { assert process.out.versions }
            )
        }
    }
}
