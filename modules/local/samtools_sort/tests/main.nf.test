nextflow_process {

    name "Test Process SAMTOOLS_SORT"
    script "../main.nf"
    process "SAMTOOLS_SORT"

    tag "modules"
    tag "modules_local"
    tag "samtools"
    tag "samtools/sort"

    test("Should convert SAM to sorted BAM") {

        when {
            process {
                """
                input[0] = [
                    [ id: 'test', single_end: false ],
                    file("${projectDir}/modules/local/samtools_sort/tests/data/test.sam", checkIfExists: true)
                ]
                """
            }
        }

        then {
            assertAll(
                { assert process.success },
                { assert snapshot(process.out).match() }
            )
        }
    }

    test("Should work in stub mode") {

        options "-stub"

        when {
            process {
                """
                input[0] = [
                    [ id: 'test_stub', single_end: false ],
                    file("${projectDir}/modules/local/samtools_sort/tests/data/test.sam", checkIfExists: true)
                ]
                """
            }
        }

        then {
            assertAll(
                { assert process.success },
                { assert process.out.bam },
                { assert process.out.versions }
            )
        }
    }
}
