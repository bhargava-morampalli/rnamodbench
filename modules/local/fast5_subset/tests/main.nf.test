nextflow_process {

    name "Test Process FAST5_SUBSET"
    script "../main.nf"
    process "FAST5_SUBSET"

    tag "modules"
    tag "modules_local"
    tag "fast5_subset"
    tag "nanopore"

    // Integration test disabled due to Docker permission issues (AccessDeniedException)

    test("Should work in stub mode") {

        options "-stub"

        when {
            process {
                """
                input[0] = [
                    [ id: 'test_stub', fast5_dir: "${projectDir}/modules/local/fast5_subset/tests/data/fast5_input" ],
                    file("${projectDir}/modules/local/fast5_subset/tests/data/read_ids.txt", checkIfExists: true),
                    file("${projectDir}/modules/local/fast5_subset/tests/data/fast5_input", checkIfExists: true)
                ]
                """
            }
        }

        then {
            assertAll(
                { assert process.success },
                { assert process.out.fast5 },
                { assert process.out.versions }
            )
        }
    }
}
